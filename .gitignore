# ══════════════════════════════════════════════════
# Whitelist-based .gitignore
# デフォルト全除外 → OSS公開対象のみ許可
# ══════════════════════════════════════════════════

# Step 1: 全て除外
*

# Step 2: ディレクトリの探索を許可（中身は個別に許可）
!*/

# Step 3: OSS公開対象ファイルを許可
!.gitignore
!.gitattributes
!.gitleaks.toml
!CLAUDE.md
!LICENSE
!README.md
!README_ja.md
!CHANGELOG.md
!CONTRIBUTING.md
!SECURITY.md

# Claude Code settings (spinner verbs only, no secrets)
!.claude/
!.claude/settings.json

# Instructions (core OSS)
!instructions/
!instructions/shogun.md
!instructions/karo.md
!instructions/ashigaru.md
!instructions/gunshi.md

# Multi-CLI: CLI-specific tool descriptions
!instructions/cli_specific/
!instructions/cli_specific/claude_tools.md
!instructions/cli_specific/codex_tools.md
!instructions/cli_specific/copilot_tools.md
!instructions/cli_specific/kimi_tools.md
!instructions/cli_specific/gemini_tools.md
!instructions/cli_specific/localapi_tools.md
!instructions/cli_specific/opencode_tools.md
!instructions/cli_specific/kilo_tools.md

# Multi-CLI: Build template parts (roles, common sections)
!instructions/roles/
!instructions/roles/*.md
!instructions/common/
!instructions/common/*.md

# Multi-CLI: Generated instruction files (built by build_instructions.sh)
!instructions/generated/
!instructions/generated/*.md

# Multi-CLI: CLI adapter library + ntfy auth
!lib/
!lib/agent_status.sh
!lib/cli_adapter.sh
!lib/inbox_path.sh
!lib/ntfy_auth.sh
!lib/topology_adapter.sh

# Multi-CLI: Codex auto-load file
!AGENTS.md

# Setup and deployment scripts
!shutsujin_departure.sh
!first_setup.sh
!setup.sh
!install.bat
!updater.bat
!scripts/stop_and_apply_update.sh

# Development tooling
!Makefile

# Config (sample files only, no secrets)
!config/
!config/ntfy_auth.env.sample

# Templates
!templates/
!templates/**

# Kimi K2 agent config
!agents/
!agents/default/
!agents/default/system.md
!agents/default/agent.yaml

# Context README
!context/
!context/README.md

# Scripts
!scripts/
!scripts/inbox_write.sh
!scripts/inbox_watcher.sh
!scripts/watcher_supervisor.sh
!scripts/ntfy.sh
!scripts/ntfy_listener.sh
!scripts/build_instructions.sh
!scripts/localapi_repl.py
!scripts/configure_agents.sh
!scripts/goza_no_ma.sh
!scripts/android_tmux_proxy.py
!scripts/sync_gemini_settings.py
!scripts/sync_opencode_config.py
!scripts/sync_runtime_cli_preferences.py
!scripts/runtime_cli_pref_daemon.sh
!scripts/goza_layout_autosave.sh
!scripts/shogun_to_karo_bridge.py
!scripts/shogun_to_karo_bridge_daemon.sh
!scripts/karo_done_to_shogun_bridge.py
!scripts/karo_done_to_shogun_bridge_daemon.sh
!scripts/history_book.sh
!scripts/mux_parity_smoke.sh
!scripts/seo_qc.sh
!scripts/seo_qc.py
!scripts/slim_yaml.sh
!scripts/slim_yaml.py
!scripts/ensure_generated_instructions.sh
!scripts/prepublish_check.sh
!scripts/upstream_sync.sh
!scripts/update_manager.py


# SayTask (sample template only, not actual data)
!saytask/
!saytask/streaks.yaml.sample

# Docs
!docs/
!docs/*.md
!docs/**/*.md

# Screenshots (masked — no secrets)
!images/
!images/screenshots/
!images/screenshots/ntfy_saytask_rename.jpg
!images/screenshots/ntfy_cmd043_progress.jpg
!images/screenshots/ntfy_bloom_oc_test.jpg
!images/screenshots/ntfy_persona_eval_complete.jpg
!images/screenshots/ntfy_tasklist_v1_before.jpg
!images/screenshots/ntfy_tasklist_v2_aligned.jpg
!images/screenshots/ntfy_tasklist_final.jpg
!images/screenshots/tdd_ndd_rdd.png

# Skills (skill-creator only)
!skills/
!skills/skill-creator/
!skills/skill-creator/SKILL.md

# Tests
!tests/
!tests/*.bats
!tests/helpers/
!tests/helpers/*.bash
!tests/unit/
!tests/unit/*.bats
!tests/unit/*.py
!tests/integration/
!tests/integration/*.bats
!tests/test_helper/
!tests/test_helper/README.md

# CI/CD
!.github/
!.github/copilot-instructions.md
!.github/workflows/
!.github/workflows/*.yml

# queue は実行時データを基本的に追跡しない
!queue/
queue/**

# Runtime / local-only artifacts
Waste/
_trash/
.shogunate/

# Upstream参照用のローカルcloneは追跡しない
_upstream_reference/

# Private/local docs are kept out of OSS publication
docs/WORKLOG.md
docs/HANDOVER_*.md
docs/UPSTREAM_SYNC_*.md

# Local user config is never published
config/settings.yaml
